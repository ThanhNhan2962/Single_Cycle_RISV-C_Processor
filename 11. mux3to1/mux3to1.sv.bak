module mux3to1 (
	input logic [1:0]       i_sel,
	input logic [31:0] i_data_01,
	input logic [31:0] i_data_10,
	input logic [31:0] i_data_10,
	output logic [31:0] o_data
);

  assign o_data = (i_sel == 2'b01) ? i_data_01 :
                  (i_sel == 2'b10) ? i_data_10 :
                  (i_sel == 2'b11) ? i_data_11 : 32'b0 ;
	
endmodule : mux3to1